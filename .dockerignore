# Keep the build context small and secrets out of the image.
.git
.github
.venv
venv
__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Secrets must never enter a layer.
.env
.env.*
!.env.example
*.pem
*.key

# Not needed at runtime.
tests
docs
infrastructure
docker-compose.yml
Makefile
.pre-commit-config.yaml
graphify-out
.DS_Store
