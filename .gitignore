# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl IS committed on purpose: it pins provider versions+hashes so CI and
# every dev resolve the same providers. Regenerate with `terraform providers lock`.

# Graphify (generated knowledge-graph index)
graphify-out/
.graphify_*

# OS/editor
.DS_Store
.vscode/
.idea/

# Local scan/demo outputs (generated by `make demo` / `agentguard scan`)
agentguard-demo-report.html
*.sarif
agentguard-report.html
