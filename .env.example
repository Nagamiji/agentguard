# Copy to .env for local dev. NEVER commit .env. All vars are prefixed KEEL_.
KEEL_APP_ENV=dev
KEEL_LOG_LEVEL=INFO
# docker-compose publishes Postgres on 5433 (avoids clashing with a native 5432).
# The app connects as keel_app (least-privilege): superusers bypass RLS and would
# silently disable tenant isolation. Migrations use the owner role.
KEEL_DATABASE_URL=postgresql+psycopg://keel_app:keel_app@localhost:5433/keel
KEEL_MIGRATION_DATABASE_URL=postgresql+psycopg://keel:keel@localhost:5433/keel
KEEL_REDIS_URL=redis://localhost:6379/0

# --- Evaluation: real model execution (EVAL-02) ---
# NO API KEY HERE, on purpose. Vertex uses Application Default Credentials:
#   gcloud auth application-default login
# so this process holds no credential of its own and a leaked .env leaks nothing.
# GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION are honoured if KEEL_VERTEX_* are unset.
KEEL_VERTEX_PROJECT=
KEEL_VERTEX_LOCATION=us-central1
KEEL_VERTEX_MODEL=gemini-2.5-flash
# Bound every run: an agent that loops must cost a bounded amount and fail, not run up a bill.
KEEL_EVAL_MAX_TURNS=6
KEEL_EVAL_TIMEOUT_SECONDS=60

# --- Deployment gate: verdict signing (Phase 5) ---
# Set to enable HMAC signatures on gate verdicts (keel/signing.py). Empty = signing off.
# Symmetric integrity for a key-holder, NOT third-party non-repudiation. Keep it secret.
KEEL_SIGNING_SECRET=
