# AgentGuard Environment Configuration Template

# --- App Settings ---
# 'dev' or 'production'. If 'production', required secrets are strictly validated at startup.
KEEL_APP_ENV=dev
KEEL_LOG_LEVEL=INFO

# --- Database & Redis ---
# Connection string for standard app access (least-privilege role)
KEEL_DATABASE_URL=postgresql+psycopg://keel_app:keel_app@localhost:5433/keel
# Connection string for database migrations (owner role)
KEEL_MIGRATION_DATABASE_URL=postgresql+psycopg://keel:keel@localhost:5433/keel
# Connection string for Redis instance
KEEL_REDIS_URL=redis://localhost:6379/0

# --- Security Secrets (REQUIRED in production mode) ---
# High-entropy random key for session signing and crypto helpers
KEEL_SECRET_KEY=
# Pepper/secret used as a key component when hashing API keys for lookup
KEEL_API_KEY_HASH_SECRET=

# --- Integrations ---
# Cloudflare API Token for Worker edge routing / syncs
KEEL_CLOUDFLARE_TOKEN=
# Webhook secret to verify incoming payloads (e.g. from GitHub)
KEEL_WEBHOOK_SECRET=

# --- Evaluation Engine ---
# Vertex AI config (uses Application Default Credentials under the hood)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
KEEL_VERTEX_MODEL=gemini-2.5-flash
